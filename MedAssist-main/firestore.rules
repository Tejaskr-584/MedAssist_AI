rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, displayName, email, createdAt
    //
    // Collection: /users/{userId}/symptomChecks/{checkId}
    // Fields: uid, symptoms, analysis, timestamp, isEmergency
    //
    // Collection: /users/{userId}/medicalRecords/{recordId}
    // Fields: uid, recordType, content, originalDiagnosis, medication, timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ssshanmukha.emani@gmail.com" && request.auth.token.email_verified == true);
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidSymptomCheck(data) {
      return data.keys().hasAll(['uid', 'symptoms', 'analysis', 'timestamp']) &&
             data.uid is string &&
             data.symptoms is string && data.symptoms.size() < 5000 &&
             data.analysis is string && data.analysis.size() < 10000 &&
             data.timestamp is string;
    }

    function isValidMedicalRecord(data) {
      return data.keys().hasAll(['uid', 'recordType', 'content', 'timestamp']) &&
             data.uid is string &&
             data.recordType in ['blood_test', 'diagnosis', 'other'] &&
             data.content is string && data.content.size() < 20000 &&
             data.timestamp is string;
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['uid', 'doctorId', 'checkId', 'transcript', 'status', 'timestamp']) &&
             data.uid is string &&
             data.doctorId is string &&
             data.checkId is string &&
             data.transcript is string && data.transcript.size() < 20000 &&
             data.status in ['pending', 'reviewed'] &&
             data.timestamp is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /symptomChecks/{checkId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSymptomCheck(request.resource.data);
        allow update: if isOwner(userId) && isValidSymptomCheck(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /medicalRecords/{recordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMedicalRecord(request.resource.data);
        allow update: if isOwner(userId) && isValidMedicalRecord(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /consultations/{consultationId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid && isValidConsultation(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
